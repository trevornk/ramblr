<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Registers github-flavor-only Activities. This file is merged with app/src/main's
         AndroidManifest.xml by Gradle/AGP's per-variant manifest merger for the "github" flavor
         only; the "storefront" flavor's manifest merge never sees this file, so
         SelfUpdateSettingsActivity is only ever declared (and therefore only ever launchable) in
         github-flavor builds, matching the flavor-source-set isolation SelfUpdateChecker.kt's
         AGENTS note establishes for the rest of this feature (Part 3, Settings UI). -->

    <!-- Part 4 (SelfUpdateInstallWorker/SelfUpdateInstaller): lets a silent PackageInstaller
         session (USER_ACTION_NOT_REQUIRED) skip Android's install confirmation dialog on API 31+
         when this app is updating itself; see SelfUpdateInstaller.kt's kdoc for the full,
         verified contract (normal protection level, no runtime prompt). Below API 31, or if any
         other precondition isn't met, this permission simply has no effect and the standard
         confirmation-dialog PackageInstaller flow is used instead (SelfUpdateInstaller.install's
         fallback); github-flavor only, same policy reasoning as everything else in this file. -->
    <uses-permission android:name="android.permission.UPDATE_PACKAGES_WITHOUT_USER_ACTION" />

    <!-- Required base permission for a non-privileged app to create/commit a PackageInstaller
         session at all (#106 audit finding): UPDATE_PACKAGES_WITHOUT_USER_ACTION above only
         upgrades an already-permitted install to skip the confirmation dialog; it does not by
         itself grant install authority. Without this, PackageInstaller.Session.commit() throws
         SecurityException on both the silent (API 31+, USER_ACTION_NOT_REQUIRED) and the
         standard confirmation-dialog fallback paths in SelfUpdateInstaller.kt, i.e. self-update
         was non-functional in every github-flavor build regardless of Android version. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application>
        <activity android:name=".SelfUpdateSettingsActivity" android:exported="false"
            android:configChanges="screenLayout|smallestScreenSize|screenSize|orientation|keyboardHidden|uiMode" />

        <!-- Manifest-declared (not context-registered) so PackageInstaller's commit-status
             PendingIntent can still be delivered even if the process that started the install
             session has since died; see SelfUpdateInstallReceiver's kdoc. -->
        <receiver android:name=".SelfUpdateInstallReceiver" android:exported="false" />
    </application>
</manifest>
