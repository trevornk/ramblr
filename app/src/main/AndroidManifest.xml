<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Install-time, no user prompt: needed to register the default-network callback that
         resets the cleanup waterfall cursor on SSID/VPN changes (#61, ADR-0001). -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:allowBackup="false"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.PhoneWhisper">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:configChanges="screenLayout|smallestScreenSize|screenSize|orientation|keyboardHidden|uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Per-category Settings screens (#93 restructure): internal only, launched from
             MainActivity's category rows and never from outside the app.

             configChanges (#80 follow-up): a Pixel Fold's fold/unfold is a screenLayout +
             smallestScreenSize configuration change, same category as a rotation. Without this,
             Android's default behavior is to fully destroy and recreate the Activity: any
             transient in-memory UI state that isn't itself persisted (most visibly, an open
             AlertDialog like CloudProviderActivity's Add/Edit provider dialog) is lost, even
             though persisted SharedPreferences-backed settings correctly survive because they
             never lived in the destroyed Activity instance to begin with. Declaring these
             config changes here means Android reconfigures the existing Activity instance in
             place instead, so open dialogs (and anything else transient) survive a fold/unfold
             just like they'd survive backgrounding the app. -->
        <activity android:name=".SetupActivity" android:exported="false"
            android:configChanges="screenLayout|smallestScreenSize|screenSize|orientation|keyboardHidden|uiMode" />
        <activity android:name=".TranscriptionActivity" android:exported="false"
            android:configChanges="screenLayout|smallestScreenSize|screenSize|orientation|keyboardHidden|uiMode" />
        <activity android:name=".CleanupActivity" android:exported="false"
            android:configChanges="screenLayout|smallestScreenSize|screenSize|orientation|keyboardHidden|uiMode" />
        <activity android:name=".LivePreviewActivity" android:exported="false"
            android:configChanges="screenLayout|smallestScreenSize|screenSize|orientation|keyboardHidden|uiMode" />
        <activity android:name=".CloudProviderActivity" android:exported="false"
            android:configChanges="screenLayout|smallestScreenSize|screenSize|orientation|keyboardHidden|uiMode" />
        <activity android:name=".AdvancedActivity" android:exported="false"
            android:configChanges="screenLayout|smallestScreenSize|screenSize|orientation|keyboardHidden|uiMode" />

        <service
            android:name=".WhisperAccessibilityService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- ModelDownloadWorker promotes itself to a foreground service while a model download is
             in progress, so it needs a declared type (required on API 34+, #56). Overrides
             WorkManager's own manifest entry for this service. -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

        <!-- No-UI trampoline reached only via the "icon hidden" notification's own explicit
             PendingIntent (Feature B, IconVisibilityNotifications); never invoked from outside
             this app. Must be an Activity (not a BroadcastReceiver) so tapping the notification
             gets the normal, immediate shade-collapse animation instead of a lingering one. The
             translucent/no-history theme keeps it fully invisible and out of Recents. -->
        <activity
            android:name=".RestoreIconActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:noHistory="true" />

    </application>
</manifest>
